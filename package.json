{
  "name": "dogeedge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/write-build-version.mjs",
    "dev": "vite",
    "local-worker": "node scripts/dogeedge-local-worker.mjs",
    "factory:worker": "node scripts/dogeedge-local-worker.mjs",
    "factory:backtest": "node scripts/dogeedge-backtest.mjs",
    "factory:sweep": "node scripts/dogeedge-backtest.mjs --sweep",
    "factory:deep-sweep": "node scripts/dogeedge-backtest.mjs --sweep --deep",
    "factory:validate": "node scripts/dogeedge-backtest.mjs --validate",
    "factory:replay-run": "node scripts/dogeedge-backtest.mjs --replay-run",
    "factory:compare": "node scripts/dogeedge-backtest.mjs --compare",
    "factory:promote-check": "node scripts/dogeedge-backtest.mjs --sweep --promote-check",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
